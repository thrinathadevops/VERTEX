# ═══════════════════════════════════════════════════════════════
#  VAREX AI Interview Platform — Backend Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
AI_INTERVIEW_DB=ai_interview_db
AI_INTERVIEW_DB_USER=ai_interview
AI_INTERVIEW_DB_PASSWORD=ai_interview_password
AI_INTERVIEW_DATABASE_URL=postgresql+psycopg2://ai_interview:ai_interview_password@ai_interview_db:5432/ai_interview_db
AI_INTERVIEW_ALLOWED_ORIGINS=["http://localhost:3010,http://localhost:3000"]

# ── JWT Authentication ─── ────────────────────────────────
# Change this to a secure random string before deploying to production!
SECRET_KEY=dev-secret-key-change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI Provider ──────────────────────────────────────────
# Choose one: gemini | openai |   ollama
AI_PROVIDER=gemini

# Google Gemini (recommended for development — free tier)
# TODO: Add your Gemini API Key below
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (recommended for production)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# Ollama (self-hosted, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Resume Upload ────────────────────────────────────────
MAX_RESUME_SIZE_MB=5

# ── Interview Timer Defaults ─────────────────────────────
DEFAULT_TOTAL_TIME_SECONDS=2700
DEFAULT_QUESTION_TIME_SECONDS=300

# ── Anti-Cheat ───────────────────────────────────────────
MAX_TAB_SWITCHES_BEFORE_FLAG=3

# ── Question Counts Per Mode ─────────────────────────────
QUESTIONS_MOCK_FREE=5
QUESTIONS_MOCK_PAID=8
QUESTIONS_ENTERPRISE=12
